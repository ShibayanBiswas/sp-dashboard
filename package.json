{
  "name": "sp-dashboard",
  "version": "0.1.0",
  "private": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev --port 3000",
    "dev:all": "bash start-dashboard.sh",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "verify:stack": "npm run typecheck && npm run lint && npm run build && npm run verify:kpis",
    "verify": "npx tsx scripts/bake-master-seed.ts && npx tsx scripts/verify-products.ts && npx tsx scripts/verify-full-suite.ts",
    "verify:full": "npx tsx scripts/verify-full-suite.ts",
    "verify:kpis": "npx tsx scripts/verify-lifecycle-kpis.ts",
    "verify:analytics": "npx tsx scripts/verify-analytics-plots.ts",
    "bake": "npx tsx scripts/bake-master-seed.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "latest",
    "@radix-ui/react-scroll-area": "latest",
    "@radix-ui/react-select": "latest",
    "@radix-ui/react-slot": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "date-fns": "latest",
    "framer-motion": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "recharts": "latest",
    "tailwind-merge": "latest",
    "xlsx": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "latest",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "latest",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "latest"
  }
}
