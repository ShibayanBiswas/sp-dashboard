# MongoDB (optional — master persistence + index price history)
# Option A: full URI (Atlas, auth, TLS)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=sp_dashboard

# Option B: build URI from parts (leave MONGODB_URI unset)
# MONGODB_HOST=127.0.0.1
# MONGODB_PORT=27017
# MONGODB_USER=
# MONGODB_PASSWORD=
# MONGODB_AUTH_SOURCE=admin
# MONGODB_TLS=false

# Start local Mongo: docker compose up -d
# Test: npm run verify:mongo

# Python analytics API (pivot fallback)
PYTHON_API_URL=http://127.0.0.1:8000
